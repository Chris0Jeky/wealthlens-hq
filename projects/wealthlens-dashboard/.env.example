# WealthLens UK — Environment Variables
# Copy to .env and adjust values for your environment.
# All variables below have sensible defaults and the app works without a .env file.
#
# NOTE: These variables are wired up in open PRs (not yet on main).
# CORS_ORIGINS is read in PR #21 (fix/cors-env-aware).
# WID_API_KEY is read in PR #17 (fix/wid-api-key-env).
# Until those PRs merge, setting these has no effect.

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# Default (when unset): http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Data pipelines
# ---------------------------------------------------------------------------

# World Inequality Database API key.
# The public default key (from the WID Stata tool repo) is used automatically
# when this variable is unset or blank — no override needed for most users.
# WID_API_KEY=your-wid-api-key-here
