# WealthLens UK — Backend environment variables
# Copy to .env and adjust values for your environment.

# Comma-separated list of allowed CORS origins.
# Default (when unset): http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional in-memory per-IP API rate limiting. Disabled unless explicitly enabled.
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_RPM=60

# Plausible Analytics for standalone chart pages (optional).
# Used by chart_html.py when generating static chart HTML.
# PLAUSIBLE_DOMAIN=wealthlens.uk
