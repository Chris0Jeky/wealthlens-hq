{
  "name": "wealthlens-dashboard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean:shadows": "git clean -fX src scripts vite.config.js vitest.config.js",
    "prebuild": "npm run clean:shadows",
    "build": "vue-tsc -b --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "vue-tsc --noEmit",
    "pretest": "npm run clean:shadows",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:og": "tsx scripts/generate-og-images.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lighthouse": "lhci autorun --config=lighthouserc.cjs",
    "generate:sitemap": "python ../../../scripts/generate_sitemap.py"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.39",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "satori": "^0.26.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^3.3.5"
  },
  "overrides": {
    "tmp": ">=0.2.6",
    "uuid": "^11.1.1"
  }
}
