{
  "name": "wealthlens-dashboard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lighthouse": "lhci autorun --config=lighthouserc.cjs"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.3.0",
    "vitest": "^4.1.6",
    "vue-tsc": "^2.2.0"
  }
}
