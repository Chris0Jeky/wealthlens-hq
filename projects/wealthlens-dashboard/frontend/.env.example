# Backend API base URL (default: /api — uses Vite proxy in dev)
# For production, set to the full backend URL e.g. https://api.wealthlens.uk
# VITE_API_BASE_URL=/api

# Plausible Analytics — set to enable privacy-respecting tracking (optional).
# Plausible is cookieless and GDPR-compliant; no consent banner needed.
# VITE_PLAUSIBLE_DOMAIN=wealthlens.uk
