# Backend API base URL (default: /api — uses Vite proxy in dev)
# For production, set to the full backend URL e.g. https://api.wealthlens.uk
# VITE_API_BASE_URL=/api

# API mode: set to 'true' to use static JSON files instead of live API.
# Used for GitHub Pages deployment where no backend is available.
# VITE_STATIC_DATA=false

# Plausible Analytics — set to enable privacy-respecting tracking (optional).
# Plausible is cookieless and GDPR-compliant; no consent banner needed.
# VITE_PLAUSIBLE_DOMAIN=wealthlens.uk

# Buttondown newsletter — used by the newsletter signup widget.
# The newsletter ID determines the embed-subscribe endpoint.
# VITE_BUTTONDOWN_NEWSLETTER_ID=wealthlens