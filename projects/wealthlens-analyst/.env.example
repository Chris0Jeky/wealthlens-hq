# WealthLens Analyst — environment variables
# Copy to .env and fill in. NEVER commit real values.

# --- Model provider (every call goes through src/wealthlens_analyst/llm/client.py) ---
ANTHROPIC_API_KEY=your-anthropic-key
# Generation model id (kept in config, not code, so swaps don't touch call sites)
ANALYST_MODEL=claude-sonnet-4-6
# Embedding provider/model — pending ADR 0003 decision
EMBEDDING_MODEL=pending-adr-0003
# Reranker (ADR 0001: feature-flagged, default OFF; provider pending ADR 0003)
RERANK_ENABLED=false
COHERE_API_KEY=

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql+psycopg://wealthlens:wealthlens@localhost:5432/analyst

# --- Observability (self-hosted Langfuse) ---
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Budget (hard spend cap, ADR 0002; fail-closed if unset) ---
BUDGET_MONTHLY_CAP_GBP=10.00

# --- App ---
ANALYST_HOST=127.0.0.1
ANALYST_PORT=8100
APP_ENV=development
