# WealthLens Analyst — environment variables
# Copy to .env and fill in. NEVER commit real values.
#
# NOTE: config.py reads these from the PROCESS environment (there is no dotenv
# auto-load yet — tracked in tasks/inbox.md). Export them into your shell before
# `make dev` / `make ingest-slice` (bash: `set -a; . ./.env; set +a`), or set
# them in your deploy environment (H1-30 Docker Compose does this).

# --- Model provider (every call goes through src/wealthlens_analyst/llm/client.py) ---
# Generation AND embeddings both use OpenAI (Chris's provider call, 2026-06-30):
# the generation default moved from claude-sonnet-4-6 to gpt-5.4-mini. Only the one
# OPENAI_API_KEY below is needed. ANTHROPIC_API_KEY is kept (unused) for the
# provider-agnostic client seam — a future provider swap touches only client.py.
ANTHROPIC_API_KEY=
# Generation model id (kept in config, not code, so swaps don't touch call sites)
ANALYST_MODEL=gpt-5.4-mini
# Embedding model (ADR 0003 D2; dimension 1536 is baked into migration 0002)
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=your-openai-key  # read by config.py; embeddings (H1-11) + generation (H1-18)
# Reranker (ADR 0001: feature-flagged, default OFF; ADR 0003 D1: Cohere Rerank 4 Fast)
RERANK_ENABLED=false
COHERE_API_KEY=

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql+psycopg://wealthlens:wealthlens@localhost:15432/analyst

# --- Observability (self-hosted Langfuse) ---
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Budget (hard spend cap, ADR 0002; fail-closed if unset) ---
BUDGET_MONTHLY_CAP_GBP=10.00

# --- App ---
# Host/port are set by `make dev` (127.0.0.1:8100); override on the uvicorn
# command line if needed.
APP_ENV=development
