# OG image generation: vendored fonts for reproducible builds.
projects/wealthlens-dashboard/frontend/scripts/fonts/*
!projects/wealthlens-dashboard/frontend/scripts/fonts/*.ttf
!projects/wealthlens-dashboard/frontend/scripts/fonts/README.md

# Transpile artifacts — TypeScript source is canonical. The frontend build
# typechecks with `vue-tsc -b --noEmit` so these should no longer be emitted, but
# ignore them so a stray emit (or an old `vue-tsc -b`) can never be committed as a
# stale shadow that Vite/vitest would resolve in preference to the .ts source.
projects/wealthlens-dashboard/frontend/src/**/*.js
projects/wealthlens-dashboard/frontend/vite.config.js
projects/wealthlens-dashboard/frontend/vitest.config.js
projects/wealthlens-dashboard/frontend/scripts/**/*.js

# Generated static API data (built by scripts/generate_static_api.py)
# Ignore generated files but whitelist committed static fallbacks.
projects/wealthlens-dashboard/frontend/public/data/*
# Committed static fallbacks that MUST ship (they back the static/GitHub-Pages build).
# Since the route prerender (ADR 0001), CI's e2e/lighthouse lanes bake the same
# artifact deploy does, so the FULL static layer is committed: datasets.json
# enumerates the prerendered /datasets/* routes, and every page needs its data
# to bake real content (deploy still regenerates everything fresh — these are
# fallbacks, not the shipped truth). Whitelist changes stay deliberate: add a
# negation per file, produced ONLY by generate_static_api.py, never by hand.
!projects/wealthlens-dashboard/frontend/public/data/freshness.json
!projects/wealthlens-dashboard/frontend/public/data/datasets.json
!projects/wealthlens-dashboard/frontend/public/data/all-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/boe-rates.json
!projects/wealthlens-dashboard/frontend/public/data/boe-rates-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/cgt-concentration.json
!projects/wealthlens-dashboard/frontend/public/data/cgt-concentration-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/child-poverty.json
!projects/wealthlens-dashboard/frontend/public/data/child-poverty-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/gdhi-by-region.json
!projects/wealthlens-dashboard/frontend/public/data/gdhi-by-region-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/generational-wealth.json
!projects/wealthlens-dashboard/frontend/public/data/generational-wealth-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/housing-affordability.json
!projects/wealthlens-dashboard/frontend/public/data/housing-affordability-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/inheritance-tax.json
!projects/wealthlens-dashboard/frontend/public/data/inheritance-tax-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/productivity-pay.json
!projects/wealthlens-dashboard/frontend/public/data/productivity-pay-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/tax-composition.json
!projects/wealthlens-dashboard/frontend/public/data/tax-composition-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/wage-stagnation.json
!projects/wealthlens-dashboard/frontend/public/data/wage-stagnation-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/wealth-by-decile.json
!projects/wealthlens-dashboard/frontend/public/data/wealth-by-decile-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/wealth-shares.json
!projects/wealthlens-dashboard/frontend/public/data/wealth-shares-metadata.json
!projects/wealthlens-dashboard/frontend/public/data/simulator
!projects/wealthlens-dashboard/frontend/public/data/simulator/*.json
