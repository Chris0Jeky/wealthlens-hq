{
  "includeCoAuthoredBy": false,
  "enableAllProjectMcpServers": true,
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      "projects/wealthlens-dashboard/frontend/node_modules",
      ".venv",
      "projects/wealthlens-dashboard/backend/.venv"
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(*)",
      "Grep(*)",
      "Glob(*)",
      "Bash(pwd:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git stash:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git rev-parse:*)",
      "Bash(git worktree:*)",
      "Bash(gh :*)",
      "Bash(python --version:*)",
      "Bash(python -m venv:*)",
      "Bash(python -m pip:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m ruff:*)",
      "Bash(python -m mypy:*)",
      "Bash(python -m uvicorn:*)",
      "Bash(python automation/*:*)",
      "Bash(python scripts/*:*)",
      "Bash(python .claude/hooks/smoke_test.py:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(uvicorn:*)",
      "Bash(fastapi:*)",
      "Bash(uv --version:*)",
      "Bash(uv init:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv run:*)",
      "Bash(node --version:*)",
      "Bash(npm --version:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx vite:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(docker compose:*)",
      "Bash(docker build:*)",
      "Bash(docker ps:*)",
      "Bash(make :*)",
      "Bash(make:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(sudo *)",
      "Bash(curl * | sh*)",
      "Bash(wget * | sh*)",
      "Bash(npm publish:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"$env:CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.py\" --event pre",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"$env:CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_failure.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"$env:CLAUDE_PROJECT_DIR/.claude/hooks/session_start.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
